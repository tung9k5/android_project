<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_input_chat"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#BDBDBD" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create a roadmap with AI. ✨"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Fill in the information below so that AI Tutor can design the most accurate curriculum for you."
        android:textColor="#757575"
        android:textSize="14sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Subject/Skill Name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtSubjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Specific objectives">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current level:"
        android:textColor="#333333"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/spnCurrentLevel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How long can you study each day?"
        android:textColor="#333333"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/spnTimeCommitment"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Tutoring Style:"
        android:textColor="#333333"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spnMentorTone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutOtherTone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        android:hint="Enter the style you want...">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtOtherTone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnGenerateDraft"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#03A9F4"
        android:text="Get AI-assisted route planning (Cost 20 ⚡)"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>