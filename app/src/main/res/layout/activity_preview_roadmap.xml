<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#03A9F4"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Draft Roadmap"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:layout_above="@id/layoutBottomActions"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPreviewSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject: Conversational English"
                android:textColor="#333333"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPreviewGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Objective: To confidently speak with foreigners."
                android:textColor="#757575"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI has analyzed the situation and proposed the following roadmap:"
                android:textColor="#0288D1"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="16dp"
                android:background="#FAFAFA">

                <TextView
                    android:id="@+id/tvRoadmapContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:text="✨ We are currently using AI to analyze and build the roadmap... Please wait a moment..." />
            </ScrollView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtAiFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_input_chat"
            android:hint="Reason for revision (e.g., Slow down the learning pace...)"
            android:padding="12dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnRegenerate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="#F5F5F5"
            android:textColor="#757575"
            android:text="🔄 Request AI to revise (Cost 20 ⚡)" />

        <Button
            android:id="@+id/btnConfirmRoadmap"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4CAF50"
            android:text="Finalize &amp; Start Creating a Roadmap (-500 ⚡)"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>